# Resend API key for the contact form. Create one at https://resend.com/api-keys
RESEND_API_KEY=

# Where contact form submissions are delivered.
CONTACT_EMAIL=zelie@louvencourt.com

# "From" header used when sending — must be a verified Resend sender.
CONTACT_FROM=Portfolio <contact@louvencourt.com>

# Public URL of the site (used for Open Graph / canonical links).
PUBLIC_SITE_URL=https://louvencourt.com
